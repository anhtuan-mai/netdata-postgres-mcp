# netdata-postgres-mcp environment configuration
# Copy to .env and modify as needed.

# Netdata agent/parent URL
NETDATA_BASE_URL=http://host.docker.internal:19999

# PostgreSQL connection string (required)
POSTGRES_DSN=postgres://netdata:netdata@postgres:5432/netdata_metrics?sslmode=disable

# How often to collect metrics (seconds)
COLLECTION_INTERVAL_SECONDS=60

# MCP server bind address
MCP_BIND_ADDR=0.0.0.0:8765

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: fixed node identifier. Auto-detected from Netdata if empty.
# NODE_ID=my-server-01

# Optional: Netdata API key for authenticated access
# NETDATA_API_KEY=

# Optional: comma-separated list of metric contexts to collect
# ENABLED_CONTEXTS=system.cpu,system.ram,system.swap,system.io,disk.io,disk.ops,disk.util,disk.space

# Log format: text, json (json recommended for production log aggregation)
# LOG_FORMAT=text

# Automatically delete samples older than this many days (0 to disable)
# RETENTION_DAYS=30

# Optional: bearer token to protect MCP HTTP/SSE endpoints
# When set, clients must provide "Authorization: Bearer <token>" header.
# MCP_AUTH_TOKEN=my-secret-token
