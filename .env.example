# netdata-postgres-mcp environment configuration
# Copy to .env and modify as needed.

# Netdata agent/parent URL
NETDATA_BASE_URL=http://host.docker.internal:19999

# PostgreSQL connection string (required)
POSTGRES_DSN=postgres://netdata:netdata@postgres:5432/netdata_metrics?sslmode=disable

# How often to collect metrics (seconds)
COLLECTION_INTERVAL_SECONDS=60

# MCP server bind address
MCP_BIND_ADDR=0.0.0.0:8765

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: fixed node identifier. Auto-detected from Netdata if empty.
# NODE_ID=my-server-01

# Optional: Netdata API key for authenticated access
# NETDATA_API_KEY=

# Optional: comma-separated list of metric contexts to collect
# ENABLED_CONTEXTS=system.cpu,system.ram,system.swap,system.io,disk.io,disk.ops,disk.util,disk.space

# Log format: text, json (json recommended for production log aggregation)
# LOG_FORMAT=text

# Automatically delete samples older than this many days (0 to disable)
# RETENTION_DAYS=30

# Optional: bearer token to protect MCP HTTP/SSE endpoints
# When set, clients must provide "Authorization: Bearer <token>" header.
# MCP_AUTH_TOKEN=my-secret-token

# Rate limiting: max requests per second per IP (0 = disabled)
# RATE_LIMIT_RPS=100

# TLS: enable HTTPS by providing cert+key paths
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# Multi-node collection: comma-separated Netdata URLs
# NETDATA_NODES=http://node1:19999,http://node2:19999

# OpenTelemetry: OTLP gRPC endpoint for distributed tracing (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Webhook notifications for bottleneck detection (configured via YAML)
# See config.example.yaml for webhook configuration

# Connection pool tuning (via YAML config pool section)
# pool:
#   min_conns: 2
#   max_conns: 10
#   max_conn_lifetime: 30m
#   max_conn_idle_time: 5m
#   health_check_period: 30s

# Prometheus remote-write receiver is enabled at /api/v1/write
# External Prometheus instances can push metrics to this endpoint.
# NODE_ID controls the node_id assigned to remote-write samples (default: "remote-write")

# Config hot-reload: send SIGHUP to reload retention_days and other settings
# without restarting the service.
